{
  "name": "dylancorneliusportfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:tail": "bash scripts/dev-tail.sh /tmp/portfolio-dev.log 40",
    "verify:route": "bash scripts/check-short.sh verify-route bash scripts/fast-verify-route.sh",
    "verify:predeploy": "npm run check:deploy-workflow && npm run check:source-budgets && npm run check:route-boundaries && npm run build && npm run check:bundle-budgets && npm run typecheck",
    "build": "next build",
    "check:deploy-workflow": "bash scripts/check-short.sh deploy-workflow bash scripts/check-deploy-workflow.sh",
    "check:source-budgets": "bash scripts/check-short.sh source-budgets node scripts/check-source-budgets.mjs",
    "check:route-boundaries": "bash scripts/check-short.sh route-boundaries node scripts/check-route-boundaries.mjs",
    "check:bundle-budgets": "bash scripts/check-short.sh bundle-budgets node scripts/check-bundle-budgets.mjs",
    "start": "next start",
    "typecheck": "bash scripts/check-short.sh typecheck tsc --noEmit"
  },
  "dependencies": {
    "framer-motion": "^12.36.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.469.0",
    "next": "14.2.26",
    "pdfjs-dist": "^3.11.174",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-leaflet": "^4.2.1",
    "react-leaflet-cluster": "^3.1.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.17.17",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
